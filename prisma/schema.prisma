generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────

enum VehicleCategory {
  ECONOMY
  SEDAN
  SUV
  PREMIUM
}

enum VehicleFuel {
  FLEX
  GASOLINE
  ELECTRIC
  HYBRID
}

enum VehicleTransmission {
  MANUAL
  AUTOMATIC
}

enum InsuranceType {
  BASIC
  INTERMEDIATE
  PREMIUM
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  FINISHED
}

enum LeadStatus {
  NEW
  CONTACTED
  NEGOTIATING
  WON
  LOST
}

enum RentalStatus {
  SCHEDULED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum ChecklistType {
  PICKUP
  RETURN
}

// ─────────────────────────────────────────────────────────────
// Models
// ─────────────────────────────────────────────────────────────

model Vehicle {
  id           String              @id @default(cuid())
  name         String
  slug         String              @unique
  brand        String
  model        String
  year         Int
  category     VehicleCategory
  transmission VehicleTransmission
  fuel         VehicleFuel
  seats        Int
  doors        Int
  dailyRate    Decimal             @db.Decimal(10, 2)
  imageUrl      String?
  galleryImages String[]            @default([])
  tags          String[]            @default([])
  available    Boolean             @default(true)
  featured     Boolean             @default(false)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  reservations Reservation[]
  rentals      Rental[]

  @@index([category])
  @@index([available])
}

model Reservation {
  id            String            @id @default(cuid())
  vehicleId     String
  pickupDate    DateTime
  returnDate    DateTime
  rentalDays    Int
  insuranceType InsuranceType
  addons        Json              @default("[]")
  subtotal      Decimal           @db.Decimal(10, 2)
  totalPrice    Decimal           @db.Decimal(10, 2)
  status        ReservationStatus @default(PENDING)
  customerName  String
  customerPhone String
  notes         String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  vehicle       Vehicle           @relation(fields: [vehicleId], references: [id])
  lead          Lead?
  rental        Rental?

  @@index([vehicleId])
  @@index([pickupDate, returnDate])
  @@index([status])
}

model Lead {
  id            String      @id @default(cuid())
  name          String
  phone         String
  reservationId String?     @unique
  status        LeadStatus  @default(NEW)
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  reservation   Reservation? @relation(fields: [reservationId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([createdAt])
}

model Rental {
  id             String       @id @default(cuid())
  reservationId  String       @unique
  vehicleId      String
  customerName   String
  customerPhone  String
  pickupDate     DateTime
  returnDate     DateTime
  pickupMileage  Int?
  returnMileage  Int?
  status         RentalStatus @default(SCHEDULED)
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  reservation    Reservation       @relation(fields: [reservationId], references: [id])
  vehicle        Vehicle           @relation(fields: [vehicleId], references: [id])
  checklists     RentalChecklist[]

  @@index([status])
  @@index([vehicleId])
}

model RentalChecklist {
  id        String        @id @default(cuid())
  rentalId  String
  type      ChecklistType
  fuelLevel String
  mileage   Int?
  notes     String?
  photos    String[]      @default([])
  createdAt DateTime      @default(now())

  rental    Rental        @relation(fields: [rentalId], references: [id])

  @@unique([rentalId, type])
  @@index([rentalId])
}

model Addon {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String
  pricePerDay Decimal  @db.Decimal(10, 2)
  icon        String   @default("✨")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model SeasonalPricing {
  id         String   @id @default(cuid())
  name       String
  startDate  DateTime
  endDate    DateTime
  multiplier Decimal  @db.Decimal(4, 2)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@index([startDate, endDate])
  @@index([active])
}

# ──────────────────────────────────────────────────────────────
# DATABASE — Neon PostgreSQL
# ──────────────────────────────────────────────────────────────
# Get from: neon.tech → your project → Connection Details → Direct connection
# The ?sslmode=require suffix is mandatory for Neon.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.sa-east-1.aws.neon.tech/neondb?sslmode=require"

# ──────────────────────────────────────────────────────────────
# WHATSAPP
# ──────────────────────────────────────────────────────────────
# Full international number — no spaces, dashes, or + prefix.
# Brazil example: country (55) + DDD (61) + number → 5561999999999
NEXT_PUBLIC_WHATSAPP_NUMBER="5561999999999"

# ──────────────────────────────────────────────────────────────
# APP URL
# ──────────────────────────────────────────────────────────────
# Used for Open Graph, canonical URLs, and structured data.
# On Vercel: set to your production domain (e.g. https://rcarlocadora.vercel.app)
# or your custom domain once configured.
NEXT_PUBLIC_BASE_URL="https://rcarlocadora.vercel.app"

# ──────────────────────────────────────────────────────────────
# ADMIN DASHBOARD
# ──────────────────────────────────────────────────────────────
# Single admin password for /admin access.
ADMIN_PASSWORD="change-me-in-production"

# Secret key for signing admin JWT session cookies.
# Generate with: openssl rand -base64 32
ADMIN_SESSION_SECRET="change-me-in-production-use-openssl-rand-base64-32"

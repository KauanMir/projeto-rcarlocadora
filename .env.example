# ──────────────────────────────────────────────────────────────
# DATABASE — Neon PostgreSQL
# ──────────────────────────────────────────────────────────────
# Get from: neon.tech → your project → Connection Details → Direct connection
# The ?sslmode=require suffix is mandatory for Neon.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx.sa-east-1.aws.neon.tech/neondb?sslmode=require"

# ──────────────────────────────────────────────────────────────
# ADMIN DASHBOARD
# ──────────────────────────────────────────────────────────────
# Single admin password for /admin access.
# Generate a new one with: node -e "require('crypto').randomBytes(12).toString('base64').slice(0,16)" | tr -d '+/='
ADMIN_PASSWORD="change-me-in-production"

# Secret key for signing admin JWT session cookies.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ADMIN_SESSION_SECRET="change-me-in-production-use-openssl-rand-base64-32"

# ──────────────────────────────────────────────────────────────
# WHATSAPP
# ──────────────────────────────────────────────────────────────
# Full international number — no spaces, dashes, or + prefix.
# RCAR official number (resolved from wa.link/jn6p0u): 556199959334
# Brazil format: country (55) + DDD (61) + number
NEXT_PUBLIC_WHATSAPP_NUMBER="556199959334"

# ──────────────────────────────────────────────────────────────
# APP URL
# ──────────────────────────────────────────────────────────────
# Used for Open Graph, canonical URLs, and structured data.
# On Vercel: set to your production domain (e.g. https://rcarlocadora.vercel.app)
# or your custom domain once configured.
NEXT_PUBLIC_BASE_URL="https://rcarlocadora.vercel.app"

# ──────────────────────────────────────────────────────────────
# DEPLOY CHECKLIST
# ──────────────────────────────────────────────────────────────
# Before going live, confirm all of the following:
#
# 1. DATABASE_URL points to the production Neon database
# 2. ADMIN_PASSWORD is a strong, unique password (not the dev default)
# 3. ADMIN_SESSION_SECRET is a fresh 32-byte base64 string
# 4. NEXT_PUBLIC_WHATSAPP_NUMBER is set to 556199959334 (RCAR official)
# 5. Seed was run ONCE against the production database:
#      npx prisma db push          (apply schema)
#      npx tsx prisma/seed.ts      (load fleet, addons, seasonal pricing)
#    WARNING: seed.ts deletes all existing data before inserting.
#    Run it only on a fresh database. Never re-run on a database with real reservations.
